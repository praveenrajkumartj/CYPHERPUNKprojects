generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  GUEST
  MEMBER
  BUILDER
  ORGANIZER
  ADMIN
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile            Profile?
  events             Event[]              @relation("Organizer")
  registrations      Registration[]
  tickets            Ticket[]
  projects           Project[]
  applications       ProjectApplication[]
  bountyApplications BountyApplication[]
  assignedBounties   Bounty[]
  skills             UserSkill[]

  sentConnections     Connection[] @relation("SentConnections")
  receivedConnections Connection[] @relation("ReceivedConnections")
  activityLogs        ActivityLog[]
  articles            Article[]
  contributionScore   Int      @default(0) @map("contribution_score")

  @@map("users")
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String   // "PROJECT_CREATED", "USER_JOINED", "TASK_POSTED"
  message   String
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User?    @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  name           String
  bio            String?
  location       String?
  walletAddress  String?  @map("wallet_address")
  githubUrl      String?  @map("github_url")
  twitterUrl     String?  @map("twitter_url")
  linkedinUrl    String?  @map("linkedin_url")
  lookingForTeam Boolean  @default(false) @map("looking_for_team")
  hiring         Boolean  @default(false) @map("hiring")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Connection {
  id         String           @id @default(cuid())
  senderId   String           @map("sender_id")
  receiverId String           @map("receiver_id")
  status     ConnectionStatus @default(PENDING)
  createdAt  DateTime         @default(now()) @map("created_at")

  sender   User @relation("SentConnections", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedConnections", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@map("connections")
}

model Event {
  id              String   @id @default(cuid())
  title           String
  description     String
  longDescription String?  @map("long_description")
  bannerImage     String?  @map("banner_image")
  type            String // hackathon, meetup, workshop
  locationType    String   @map("location_type") // online, offline
  location        String? // Join link or Physical address
  date            DateTime
  capacity        Int      @default(100)
  organizerId     String   @map("organizer_id")
  status          String   @default("published") // draft, published
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organizer     User           @relation("Organizer", fields: [organizerId], references: [id])
  speakers      Speaker[]
  schedules     Schedule[]
  registrations Registration[]
  tickets       Ticket[]

  @@map("events")
}

model Speaker {
  id          String  @id @default(cuid())
  name        String
  designation String
  image       String?
  eventId     String  @map("event_id")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("speakers")
}

model Schedule {
  id          String  @id @default(cuid())
  time        String
  title       String
  description String?
  eventId     String  @map("event_id")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("schedules")
}

model Registration {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
  @@map("registrations")
}

model Ticket {
  id        String   @id @default(cuid())
  type      String // Basic, Premium, VIP
  price     Float    @default(0)
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@map("tickets")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  teamSize    Int      @default(1) @map("team_size")
  status      String   @default("idea") // idea, building, launched
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator      User                 @relation(fields: [createdBy], references: [id])
  applications ProjectApplication[]
  skills       ProjectSkill[]
  bounties     Bounty[]

  @@map("projects")
}

model ProjectSkill {
  projectId String @map("project_id")
  skillId   String @map("skill_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([projectId, skillId])
  @@map("project_skills")
}

model ProjectApplication {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_applications")
}

model Bounty {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  title        String
  description  String
  rewardAmount Float    @map("reward_amount")
  rewardType   String   @map("reward_type") // crypto, fiat
  deadline     DateTime
  assignedTo   String?  @map("assigned_to")
  status       String   @default("open") // open, in_progress, completed
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee     User?               @relation(fields: [assignedTo], references: [id])
  applications BountyApplication[]

  @@map("bounties")
}

model BountyApplication {
  id        String   @id @default(cuid())
  bountyId  String   @map("bounty_id")
  userId    String   @map("user_id")
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now()) @map("created_at")

  bounty Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bountyId, userId])
  @@map("bounty_applications")
}

model Skill {
  id   String @id @default(cuid())
  name String @unique

  users    UserSkill[]
  projects ProjectSkill[]

  @@map("skills")
}

model UserSkill {
  userId  String @map("user_id")
  skillId String @map("skill_id")

  user  User  @relation(fields: [userId], references: [id])
  skill Skill @relation(fields: [skillId], references: [id])

  @@id([userId, skillId])
  @@map("user_skills")
}

model Article {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  excerpt     String?  @db.Text
  coverImage  String?  @map("cover_image")
  authorId    String   @map("author_id")
  tags        String[]
  readTime    Int?     @map("read_time")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  author      User     @relation(fields: [authorId], references: [id])

  @@map("articles")
}

model Tutorial {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  category    String   // Solana, Bitcoin, etc.
  difficulty  String   // Beginner, Intermediate, Advanced
  thumbnail   String?
  lessons     Lesson[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("tutorials")
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  order       Int
  tutorialId  String   @map("tutorial_id")
  tutorial    Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  @@map("lessons")
}

model ResourceSession {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  videoUrl    String   @map("video_url")
  thumbnail   String?
  eventName   String?  @map("event_name")
  date        DateTime @default(now())
  tags        String[]
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("resource_sessions")
}

model HackathonGuide {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  sections    Section[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("hackathon_guides")
}

model Section {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  order     Int
  guideId   String   @map("guide_id")
  guide     HackathonGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@map("guide_sections")
}
