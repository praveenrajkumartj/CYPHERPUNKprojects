generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  GUEST
  MEMBER
  BUILDER
  ORGANIZER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          UserRole  @default(MEMBER)
  bio           String?
  location      String?
  walletAddress String?   @map("wallet_address")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  events        Event[]   @relation("Organizer")
  registrations Registration[]
  tickets       Ticket[]
  projects      Project[]
  applications  ProjectApplication[]
  skills        UserSkill[]
  activityLogs  ActivityLog[]
  articles      Article[]
  contributionScore Int      @default(0) @map("contribution_score")

  @@map("users")
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String   // "PROJECT_CREATED", "USER_JOINED", "TASK_POSTED"
  message   String
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User?    @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model Event {
  id           String    @id @default(cuid())
  title        String
  description  String
  longDescription String? @map("long_description")
  bannerImage  String?   @map("banner_image")
  type         String    // hackathon, meetup, workshop
  locationType String    @map("location_type") // online, offline
  location     String?   // Join link or Physical address
  date         DateTime
  capacity     Int       @default(100)
  organizerId  String    @map("organizer_id")
  status       String    @default("published") // draft, published
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  organizer     User      @relation("Organizer", fields: [organizerId], references: [id])
  speakers      Speaker[]
  schedules     Schedule[]
  registrations Registration[]
  tickets       Ticket[]

  @@map("events")
}

model Speaker {
  id          String @id @default(cuid())
  name        String
  designation String
  image       String?
  eventId     String @map("event_id")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("speakers")
}

model Schedule {
  id          String   @id @default(cuid())
  time        String
  title       String
  description String?
  eventId     String   @map("event_id")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("schedules")
}

model Registration {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
  @@map("registrations")
}

model Ticket {
  id         String   @id @default(cuid())
  type       String   // Basic, Premium, VIP
  price      Float    @default(0)
  userId     String   @map("user_id")
  eventId    String   @map("event_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@map("tickets")
}

model Project {
  id          String    @id @default(cuid())
  title       String
  description String
  status      String    @default("OPEN") // OPEN, CLOSED
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  creator      User      @relation(fields: [createdBy], references: [id])
  applications ProjectApplication[]

  @@map("projects")
}

model ProjectApplication {
  id        String @id @default(cuid())
  projectId String @map("project_id")
  userId    String @map("user_id")
  status    String @default("PENDING") // PENDING, ACCEPTED, REJECTED

  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@map("project_applications")
}

model Skill {
  id    String @id @default(cuid())
  name  String @unique

  users UserSkill[]

  @@map("skills")
}

model UserSkill {
  userId  String @map("user_id")
  skillId String @map("skill_id")

  user    User   @relation(fields: [userId], references: [id])
  skill   Skill  @relation(fields: [skillId], references: [id])

  @@id([userId, skillId])
  @@map("user_skills")
}

model Article {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  excerpt     String?  @db.Text
  coverImage  String?  @map("cover_image")
  authorId    String   @map("author_id")
  tags        String[]
  readTime    Int?     @map("read_time")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  author      User     @relation(fields: [authorId], references: [id])

  @@map("articles")
}

model Tutorial {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  category    String   // Solana, Bitcoin, etc.
  difficulty  String   // Beginner, Intermediate, Advanced
  thumbnail   String?
  lessons     Lesson[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("tutorials")
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  order       Int
  tutorialId  String   @map("tutorial_id")
  tutorial    Tutorial @relation(fields: [tutorialId], references: [id], onDelete: Cascade)

  @@map("lessons")
}

model ResourceSession {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  videoUrl    String   @map("video_url")
  thumbnail   String?
  eventName   String?  @map("event_name")
  date        DateTime @default(now())
  tags        String[]
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("resource_sessions")
}

model HackathonGuide {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  sections    Section[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("hackathon_guides")
}

model Section {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  order     Int
  guideId   String   @map("guide_id")
  guide     HackathonGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@map("guide_sections")
}
